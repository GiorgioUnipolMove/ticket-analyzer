# ──────────────────────────────────────────────────
# Provider LLM - decommenta e compila quello che usi
# ──────────────────────────────────────────────────

# Claude (https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-...

# Gemini (https://aistudio.google.com/apikey) - GRATIS
# GEMINI_API_KEY=AIza...

# Ollama - gira in locale, nessuna key necessaria
# OLLAMA_BASE_URL=http://localhost:11434

# ──────────────────────────────────────────────────
# Provider e modello di default
# ──────────────────────────────────────────────────
DEFAULT_PROVIDER=gemini
# DEFAULT_MODEL=              # lascia vuoto per usare il default del provider

# ──────────────────────────────────────────────────
# File
# ──────────────────────────────────────────────────
INPUT_FILE=Restituzione_device_aggiuntivi_ANALISI_OPS_Personale.xlsx
OUTPUT_FILE=output_analisi.xlsx

# ──────────────────────────────────────────────────
# Parametri di esecuzione
# ──────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY=5
BATCH_SAVE_EVERY=50
